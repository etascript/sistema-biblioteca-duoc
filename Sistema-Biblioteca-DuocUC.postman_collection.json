							"path": ["api", "eventos", "publicar"]
						}
					},
					"response": [
						{
							"name": "400 Bad Request - Campos obligatorios",
							"status": "Bad Request",
							"code": 400,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"error\": \"Los campos 'tipo' y 'asunto' son obligatorios. Tipos validos: PRESTAMO_CREADO, LIBRO_DEVUELTO, USUARIO_REGISTRADO\"\n}"
						}
					]
				}
			]
		},
