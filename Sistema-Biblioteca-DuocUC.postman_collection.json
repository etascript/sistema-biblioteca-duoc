		{
			"name": "GraphQL - Consultas (Queries)",
			"description": "Consultas complejas via GraphQL. Endpoint: POST /api/graphql/consultas",
			"item": [
				{
					"name": "Todos los Usuarios",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"{ usuarios { idUsuario nombre email fechaRegistro } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_CONSULTAS_URL}}/api/graphql/consultas",
							"host": ["{{AZ_GQL_CONSULTAS_URL}}"],
							"path": ["api", "graphql", "consultas"]
						}
					}
				},
				{
					"name": "Usuario con sus Prestamos",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"{ usuario(id: 1) { idUsuario nombre email prestamos { idPrestamo tituloLibro fechaPrestamo estado } } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_CONSULTAS_URL}}/api/graphql/consultas",
							"host": ["{{AZ_GQL_CONSULTAS_URL}}"],
							"path": ["api", "graphql", "consultas"]
						}
					}
				},
				{
					"name": "Todos los Libros con Categoria y Resenas",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"{ libros { idLibro titulo autor disponible categoria { nombre } resenas { calificacion comentario nombreUsuario } } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_CONSULTAS_URL}}/api/graphql/consultas",
							"host": ["{{AZ_GQL_CONSULTAS_URL}}"],
							"path": ["api", "graphql", "consultas"]
						}
					}
				},
				{
					"name": "Libro por ID",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"{ libro(id: 1) { idLibro titulo autor disponible categoria { nombre descripcion } resenas { nombreUsuario calificacion comentario fecha } } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_CONSULTAS_URL}}/api/graphql/consultas",
							"host": ["{{AZ_GQL_CONSULTAS_URL}}"],
							"path": ["api", "graphql", "consultas"]
						}
					}
				},
				{
					"name": "Todas las Categorias",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"{ categorias { idCategoria nombre descripcion } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_CONSULTAS_URL}}/api/graphql/consultas",
							"host": ["{{AZ_GQL_CONSULTAS_URL}}"],
							"path": ["api", "graphql", "consultas"]
						}
					}
				},
				{
					"name": "Libros por Categoria",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"{ librosPorCategoria(idCategoria: 1) { idLibro titulo autor disponible } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_CONSULTAS_URL}}/api/graphql/consultas",
							"host": ["{{AZ_GQL_CONSULTAS_URL}}"],
							"path": ["api", "graphql", "consultas"]
						}
					}
				},
				{
					"name": "Prestamos por Usuario",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"{ prestamosPorUsuario(idUsuario: 1) { idPrestamo tituloLibro fechaPrestamo fechaDevolucion estado } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_CONSULTAS_URL}}/api/graphql/consultas",
							"host": ["{{AZ_GQL_CONSULTAS_URL}}"],
							"path": ["api", "graphql", "consultas"]
						}
					}
				},
				{
					"name": "Resenas por Libro",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"{ resenasPorLibro(idLibro: 1) { idResena nombreUsuario calificacion comentario fecha } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_CONSULTAS_URL}}/api/graphql/consultas",
							"host": ["{{AZ_GQL_CONSULTAS_URL}}"],
							"path": ["api", "graphql", "consultas"]
						}
					}
				}
			]
		},
		{
			"name": "GraphQL - Operaciones (Mutations)",
			"description": "Mutaciones via GraphQL. Endpoint: POST /api/graphql/operaciones",
			"item": [
				{
					"name": "Crear Categoria",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"mutation { crearCategoria(nombre: \\\"Ciencia Ficcion\\\", descripcion: \\\"Obras de ciencia ficcion y fantasia\\\") { idCategoria nombre descripcion } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_OPERACIONES_URL}}/api/graphql/operaciones",
							"host": ["{{AZ_GQL_OPERACIONES_URL}}"],
							"path": ["api", "graphql", "operaciones"]
						}
					}
				},
				{
					"name": "Asignar Categoria a Libro",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"mutation { asignarCategoria(idLibro: 1, idCategoria: 1) { idLibro titulo autor } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_OPERACIONES_URL}}/api/graphql/operaciones",
							"host": ["{{AZ_GQL_OPERACIONES_URL}}"],
							"path": ["api", "graphql", "operaciones"]
						}
					}
				},
				{
					"name": "Crear Resena",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"mutation { crearResena(idUsuario: 1, idLibro: 1, calificacion: 5, comentario: \\\"Excelente lectura\\\") { idResena calificacion comentario fecha } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_OPERACIONES_URL}}/api/graphql/operaciones",
							"host": ["{{AZ_GQL_OPERACIONES_URL}}"],
							"path": ["api", "graphql", "operaciones"]
						}
					}
				},
				{
					"name": "Devolver Libro",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"mutation { devolverLibro(idPrestamo: 1) { idPrestamo estado fechaDevolucion } }\"\n}"
						},
						"url": {
							"raw": "{{AZ_GQL_OPERACIONES_URL}}/api/graphql/operaciones",
							"host": ["{{AZ_GQL_OPERACIONES_URL}}"],
							"path": ["api", "graphql", "operaciones"]
						}
					}
				}
			]
		},
		{
			"name": "Event Grid - Publicador",
			"description": "Publica eventos al Custom Topic de Azure Event Grid.\nUsa {{AZ_EG_PUBLICADOR_URL}} en Azure o {{EG_PUBLICADOR_LOCAL}} en Docker local.\n\nFlujo: este endpoint actúa como generador de eventos. Azure Event Grid enruta cada evento al suscriptor registrado (function-eventgrid-suscriptor), que lo persiste en la tabla eventos_log de Oracle.",
			"item": [
				{
					"name": "Publicar - Prestamo Creado",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tipo\": \"PRESTAMO_CREADO\",\n    \"asunto\": \"prestamos/1\",\n    \"datos\": {\n        \"idPrestamo\": \"1\",\n        \"idUsuario\": \"1\",\n        \"idLibro\": \"2\",\n        \"nombreUsuario\": \"Sebastian Cortes\",\n        \"tituloLibro\": \"Cien Anos de Soledad\"\n    }\n}"
						},
						"url": {
							"raw": "{{AZ_EG_PUBLICADOR_URL}}/api/eventos/publicar",
							"host": ["{{AZ_EG_PUBLICADOR_URL}}"],
							"path": ["api", "eventos", "publicar"]
						}
					},
					"response": [
						{
							"name": "200 OK - Evento publicado",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"mensaje\": \"Evento publicado correctamente en Azure Event Grid\",\n    \"idEvento\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n    \"tipoEvento\": \"biblioteca.prestamo.creado\",\n    \"asunto\": \"prestamos/1\",\n    \"datos\": {\n        \"idPrestamo\": \"1\",\n        \"idUsuario\": \"1\",\n        \"idLibro\": \"2\",\n        \"nombreUsuario\": \"Sebastian Cortes\",\n        \"tituloLibro\": \"Cien Anos de Soledad\"\n    }\n}"
						}
					]
				},
				{
					"name": "Publicar - Libro Devuelto",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tipo\": \"LIBRO_DEVUELTO\",\n    \"asunto\": \"prestamos/1\",\n    \"datos\": {\n        \"idPrestamo\": \"1\",\n        \"idUsuario\": \"1\",\n        \"idLibro\": \"2\",\n        \"tituloLibro\": \"Cien Anos de Soledad\",\n        \"fechaDevolucion\": \"2026-05-03\"\n    }\n}"
						},
						"url": {
							"raw": "{{AZ_EG_PUBLICADOR_URL}}/api/eventos/publicar",
							"host": ["{{AZ_EG_PUBLICADOR_URL}}"],
							"path": ["api", "eventos", "publicar"]
						}
					},
					"response": [
						{
							"name": "200 OK - Evento publicado",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"mensaje\": \"Evento publicado correctamente en Azure Event Grid\",\n    \"idEvento\": \"b2c3d4e5-f6a7-8901-bcde-f12345678901\",\n    \"tipoEvento\": \"biblioteca.prestamo.devuelto\",\n    \"asunto\": \"prestamos/1\",\n    \"datos\": {\n        \"idPrestamo\": \"1\",\n        \"idLibro\": \"2\",\n        \"fechaDevolucion\": \"2026-05-03\"\n    }\n}"
						}
					]
				},
				{
					"name": "Publicar - Usuario Registrado",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tipo\": \"USUARIO_REGISTRADO\",\n    \"asunto\": \"usuarios/3\",\n    \"datos\": {\n        \"idUsuario\": \"3\",\n        \"nombre\": \"Carlos Mendoza\",\n        \"email\": \"carlos.mendoza@duocuc.cl\"\n    }\n}"
						},
						"url": {
							"raw": "{{AZ_EG_PUBLICADOR_URL}}/api/eventos/publicar",
							"host": ["{{AZ_EG_PUBLICADOR_URL}}"],
							"path": ["api", "eventos", "publicar"]
						}
					}
				},
